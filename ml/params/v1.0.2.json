        "iterations": 10000,
        "task_type": "GPU",
        "learning_rate": 0.05,
        "depth": 6,
        "loss_function": "MultiClass",
        "early_stopping_rounds": 50,
        "verbose": 100,
        "random_seed": 42
    },
    
    "CV_FOLDS": 5,
    "RANDOM_SEED": 42
}
