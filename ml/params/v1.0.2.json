{
    "MODEL_VERSION": "v1.0.2",
    "DESCRIPTION": "The 'Production' Final Model. Includes BioBERT NLP text extraction and PCA(10) compression. Uses rigourous 5-Fold Stratified Cross Validation. CatBoost running on GPU.",
    
    "BERT_MODEL_NAME": "dmis-lab/biobert-v1.1",
    "BERT_MAX_LENGTH": 64,
    "BERT_BATCH_SIZE": 64,
